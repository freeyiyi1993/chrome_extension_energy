# Firebase 配置模板
# 复制为 .env.development (测试环境) 和 .env.production (线上环境)
#
# Vite 自动加载规则:
#   dev:web        → .env.development
#   build / build:web → .env.production
#
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google OAuth Client ID
# Web 端: Firebase Console → Authentication → Google → Web SDK configuration → Web client ID
VITE_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# Extension 端: Google Cloud Console → 创建 Chrome 扩展类型的 OAuth 客户端
VITE_GOOGLE_CLIENT_ID_EXTENSION=your_extension_client_id.apps.googleusercontent.com
